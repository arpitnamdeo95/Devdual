# Frontend URL (set this on Render.com in environment variables)
FRONTEND_URL=https://devduel.vercel.app

# Port (Render sets this automatically)
PORT=10000

# Gemini API Key (get from https://aistudio.google.com/apikey)
# If not set, the AI Review will use a realistic mock response
GEMINI_API_KEY=your_gemini_api_key_here
